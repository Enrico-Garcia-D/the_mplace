# Verification API Configuration
# Copy this to .env.local and add your actual credentials

# Verihubs API Configuration
# Get your API key from: https://dashboard.verihubs.com/api-keys
EXPO_PUBLIC_VERIHUBS_API_KEY=your_api_key_here

# Optional: If you need a custom Verihubs endpoint
# EXPO_PUBLIC_VERIHUBS_API_URL=https://api.verihubs.com/v1

# Firebase Configuration (if not already set)
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
